# ── Gemini (optional; only for news summarization step) ──
# Get your key from https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ── NewsAPI (optional; for SCMP / China news) ──
# NEWSAPI_KEY=your-newsapi-key-here

# ── Web API (Render / frontend) ───────────────────
# Restrict CORS to your frontend origin(s), comma-separated. Leave unset to allow *.
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-app.onrender.com

# ── Pipeline defaults ──────────────────────────────
# LOG_LEVEL=INFO
# CACHE_RAW_HTML=true
